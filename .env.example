# LocalStack Configuration
# Get your Developer Auth Token from: https://app.localstack.cloud/workspace/auth-tokens
# 
# INSTRUCTIONS:
# 1. Sign up at https://app.localstack.cloud/sign-up (14-day free trial)
# 2. Go to https://app.localstack.cloud/workspace/auth-tokens
# 3. Copy your Developer Auth Token
# 4. Replace the value below (DO NOT commit this file to git!)

LOCALSTACK_AUTH_TOKEN=your_developer_auth_token_here

# Optional: LocalStack Configuration
# LOCALSTACK_HOST=localhost
# LOCALSTACK_PORT=4566
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
