htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
*.cover
*.log

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

